# Copy this file to .env and fill in your values
# NEVER commit .env to Git

# MySQL
DB_ROOT_PASS=your_root_password_here
DB_USER=revpay_user
DB_PASS=your_db_password_here

# JWT — must be at least 32 characters
JWT_SECRET=your_very_long_jwt_secret_key_minimum_32_characters_here

# Eureka Dashboard credentials
EUREKA_USERNAME=admin
EUREKA_PASSWORD=admin
